# =============================================================================
# ClaudePaw Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Run `npm run setup` for an interactive wizard that generates .env for you.
# =============================================================================

# === Telegram ===

# Bot token from @BotFather on Telegram
# Create a bot: https://t.me/BotFather -> /newbot
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID (numeric). Send /start to @userinfobot to find yours.
ALLOWED_CHAT_ID=

# === Claude Code ===

# Working directory for Claude Code agent sessions
CLAUDE_CWD=.

# === Voice STT ===

# Speech-to-text endpoint (WhisperX or OpenAI-compatible API)
STT_URL=http://localhost:8010/v1/audio/transcriptions

# STT model identifier
STT_MODEL=Systran/faster-whisper-large-v3

# === Voice TTS ===

# Text-to-speech endpoint (Chatterbox TTS)
TTS_URL=http://localhost:8095/v1/tts

# TTS voice preset
TTS_VOICE=default

# === Dashboard ===

# On first boot, if the users table is empty and this is set, the server auto-creates
# an admin user seeded with this token hashed. After that first boot you manage users
# via the Users admin page. The env var remains valid as the admin's "bootstrap token"
# until it's revoked; rotate or drop it once additional admin tokens exist.
# Generate with: openssl rand -hex 32
DASHBOARD_API_TOKEN=

# Secret used to sign short-lived OAuth state JWTs during the Google OAuth flow.
# Required for the Reconnect button and any OAuth integration auth. Without this,
# OAuth will return 503. Generate with: openssl rand -hex 32
DASHBOARD_JWT_SECRET=

# Optional: override the bootstrap admin's email and display name. Defaults:
# admin@claudepaw.local / Admin. Only used when the users table is empty at boot.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_NAME=

# Bot identity token. The bot uses this to authenticate callbacks to the dashboard
# (chat results, research updates, paws sync). Distinct from DASHBOARD_API_TOKEN
# so the dashboard can distinguish bot writes from human admin writes via the
# requireBotOrAdmin middleware. Generate with: openssl rand -hex 32.
# If unset, the bot falls back to DASHBOARD_API_TOKEN (which still works because
# admin bypasses requireBotOrAdmin).
BOT_API_TOKEN=

# Optional: override the bot user's email/name (only used at first bootstrap).
# Defaults: bot@claudepaw.local / ClaudePaw Bot
BOT_USER_EMAIL=
BOT_USER_NAME=

# Shared HMAC-SHA256 secret for WebSocket auth.
# Used both by the bot (mac-primary) and by browser-client WS tickets.
# REQUIRED in production. Generate with: openssl rand -hex 32
WS_SECRET=

# AES-256-GCM key for credential encryption (integrations, OAuth tokens, etc).
# REQUIRED in production. MUST be 64 hex chars (32 bytes). The server refuses
# to boot with a missing or malformed key; override for local testing by
# setting ALLOW_MISSING_CREDENTIAL_KEY=1 (degraded mode).
# Generate with: openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY=

# Dashboard server URL (used by the bot for OAuth tokens, metrics, and live status).
# Local install (bot + dashboard on same machine): http://localhost:3000
# Split install (dashboard on a separate server): http://<server-ip>:3000
# Run `npm run setup` to configure this automatically.
DASHBOARD_URL=http://localhost:3000

# Set to 'true' to skip the 2am auto-upgrade. Use until signed-tag verification lands.
DISABLE_AUTO_UPGRADE=

# === Logging ===

# Log verbosity: debug, info, warn, error
LOG_LEVEL=info

# === Channels ===

# Comma-separated list of enabled messaging channels.
# Options: telegram, discord, whatsapp, slack, imessage
CHANNELS_ENABLED=telegram

# --- Discord ---

# Discord bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# Comma-separated Discord user IDs allowed to interact with the bot
DISCORD_ALLOWED_USER_IDS=

# --- WhatsApp ---

# Directory for WhatsApp session auth data (defaults to store/whatsapp-auth)
WHATSAPP_AUTH_DIR=

# Comma-separated phone numbers allowed to interact (E.164 format, e.g. +1234567890)
WHATSAPP_ALLOWED_NUMBERS=

# --- Slack ---

# Slack bot token (xoxb-...) from https://api.slack.com/apps
SLACK_BOT_TOKEN=

# Slack app-level token (xapp-...) for Socket Mode
SLACK_APP_TOKEN=

# Comma-separated Slack user IDs allowed to interact
SLACK_ALLOWED_USER_IDS=

# --- iMessage ---

# Comma-separated iMessage handles (phone numbers or emails) allowed to interact.
# Requires macOS with Messages.app configured.
IMESSAGE_ALLOWED_HANDLES=

# === Agents ===

# Comma-separated agent IDs to enable.
# Shipped agents: auditor, healer, sentinel, strategist
# Templates in templates/: analyst, content-creator, critic, marketing-lead, orchestrator, researcher, social-manager
# Copy templates to agents/ and add their IDs here.
ENABLED_AGENTS=auditor,healer,sentinel,strategist

# === Security Scanner ===

# Comma-separated absolute paths to project directories to scan
SECURITY_PROJECT_PATHS=

# Comma-separated domains to monitor (e.g. example.com,api.example.com)
SECURITY_DOMAINS=

# Comma-separated Tailscale hostnames to check
SECURITY_TAILSCALE_NODES=

# GitHub username or org for repo scanning
SECURITY_GITHUB_OWNER=

# JSON object mapping hostnames to expected open ports.
# Example: {"my-server":["22","443"],"dev-box":["8080"]}
SECURITY_EXPECTED_PORTS={}

# Maximum severity level for auto-fix (low, medium, high, critical)
SECURITY_AUTO_FIX_MAX_SEVERITY=medium

# === Social Posting ===

# --- Twitter/X (OAuth 1.0a User Context) ---
# Get credentials at https://developer.x.com/en/portal/dashboard

# API key (consumer key)
TWITTER_API_KEY=

# API secret (consumer secret)
TWITTER_API_SECRET=

# User access token with tweet.write scope
TWITTER_ACCESS_TOKEN=

# User access token secret
TWITTER_ACCESS_SECRET=

# --- LinkedIn (OAuth 2.0) ---

# OAuth 2.0 token with w_member_social scope
LINKEDIN_ACCESS_TOKEN=

# Your LinkedIn person URN (format: urn:li:person:XXXXXXXXXX)
LINKEDIN_PERSON_URN=

# === Google APIs ===

# OAuth 2.0 credentials from https://console.cloud.google.com/apis/credentials
# Used for Gmail, Calendar, Sheets, and Drive integrations
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === Newsletter ===

# Gemini API key for newsletter content generation
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Email address to receive generated newsletters
NEWSLETTER_RECIPIENT=

# === Guard Sidecar ===

# URL for the Guard sidecar service (input/output safety filtering)
GUARD_SIDECAR_URL=http://localhost:8099
